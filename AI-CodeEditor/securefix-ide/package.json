{
  "name": "securefix-ide",
  "version": "0.1.0",
  "description": "Security-Focused Standalone IDE with AI-Powered Vulnerability Detection and Fix Generation",
  "private": true,
  "workspaces": [
    "core",
    "gui",
    "desktop",
    "extensions/vscode",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:gui && npm run build:desktop",
    "build:core": "npm run build --workspace=core",
    "build:gui": "npm run build --workspace=gui",
    "build:desktop": "npm run build --workspace=desktop",
    "build:extension": "npm run build --workspace=extensions/vscode",
    "dev": "npm run dev:desktop",
    "dev:desktop": "npm run dev --workspace=desktop",
    "dev:gui": "npm run dev --workspace=gui",
    "dev:core": "npm run dev --workspace=core",
    "watch:extension": "npm run watch --workspace=extensions/vscode",
    "start": "npm run dev --workspace=desktop",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test --workspaces --if-present",
    "clean": "rimraf node_modules */node_modules */*/node_modules"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "interpret": "^3.1.1",
    "monaco-editor": "^0.45.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.0",
    "rechoir": "^0.8.0",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
