# SecureFix AI Fix Engine - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Application Settings
# ============================================================================
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=sqlite+aiosqlite:///./securefix.db

# ============================================================================
# Azure OpenAI Configuration (Recommended)
# ============================================================================
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# ============================================================================
# Standard OpenAI Configuration (Alternative)
# ============================================================================
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4-turbo-preview

# ============================================================================
# LLM Settings
# ============================================================================
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_STREAMING=true

# ============================================================================
# Context Extraction Settings
# ============================================================================
CONTEXT_LINES_BEFORE=15
CONTEXT_LINES_AFTER=15
MAX_IMPORTS_TO_INCLUDE=50

# ============================================================================
# CORS Settings
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# ============================================================================
# Phase 1 Backend Integration (Optional)
# ============================================================================
PHASE1_BACKEND_URL=http://localhost:5000
